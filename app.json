{
  "expo": {
    "name": "Compras Reais",
    "slug": "compras-reais",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O app precisa acessar a câmera para fotografar produtos e preços.",
        "NSPhotoLibraryUsageDescription": "O app precisa acessar a galeria para selecionar fotos de produtos."
      }
    },
    "android": {
      "package": "com.joaoxmarcello.comprasreais",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "O app precisa acessar a câmera para fotografar produtos e preços."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar a galeria para selecionar fotos de produtos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6bf53bc6-af96-426c-a1a0-00193f4e4bc9"
      }
    }
  }
}
